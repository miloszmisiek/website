---
import { FadeIn, FADE_DELAY } from "../components/FadeIn";
import TimelineEntry from "../components/timeline/TimelineEntry/index.astro";
import TimelineAnimator from "../components/timeline/TimelineAnimator";
import { AnimatedSectionTitle } from "../components/arrayTitle/AnimatedSectionTitle";
import { getExperience, getTranslations } from "../i18n";

const experience = getExperience(Astro.currentLocale);
const t = getTranslations(Astro.currentLocale);
---

<section id="experience" class="mb-32 scroll-mt-28 short:mb-16">
  {/* Section Header */}
  <div class="section-label">
    <span class="section-num">01</span>
    <AnimatedSectionTitle client:load text={t("section.experience")} />
  </div>

  {/* Timeline */}
  <FadeIn client:load delay={FADE_DELAY.sm} scrollTriggered>
    <div class="pt-4">
      <div class="timeline-container">
        <span class="trunk-label">* main</span>
        <div class="trunk"></div>

        <TimelineAnimator client:load items={experience}>
          {
            experience.map((entry, index) => (
              <TimelineEntry entry={entry} index={index} />
            ))
          }
        </TimelineAnimator>
      </div>
    </div>
  </FadeIn>
</section>

<script>
  function setupTimelineObserver() {
    const entries = document.querySelectorAll(".timeline-entry");
    if (!entries.length) return;

    const observer = new IntersectionObserver(
      (entriesList) => {
        entriesList.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }
          entry.target.classList.add("is-active");
          observer.unobserve(entry.target);
        });
      },
      {
        rootMargin: "-30% 0px -40% 0px",
        threshold: 0,
      },
    );

    entries.forEach((entry) => observer.observe(entry));
  }

  // Run on initial load
  setupTimelineObserver();

  // If using view transitions, ensure it runs on navigation
  document.addEventListener("astro:page-load", setupTimelineObserver);
</script>

<style>
  .timeline-container {
    position: relative;
    padding-top: 1.5rem;
    margin-left: 1rem;
  }

  @media (min-width: 768px) {
    .timeline-container {
      margin-left: 2rem;
    }
  }
  @media (min-width: 1024px) {
    .timeline-container {
      margin-left: 3rem;
    }
  }

  /* Dashed vertical trunk */
  .trunk {
    position: absolute;
    left: 0;
    top: 0rem;
    bottom: 0;
    width: 1px;
    background-image: repeating-linear-gradient(
      to bottom,
      var(--color-line) 0px,
      var(--color-line) 6px,
      transparent 6px,
      transparent 12px
    );
  }

  /* * main label above trunk */
  .trunk-label {
    position: absolute;
    left: 6px;
    top: -20px;
    font-family: theme("fontFamily.mono-system");
    font-size: 0.62rem;
    color: var(--color-dim);
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
</style>
