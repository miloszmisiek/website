---
type Props = {
  role: string;
  company: string;
};

const { role, company } = Astro.props;
---

<h3 class="text-heading-md mb-2">{role}</h3>
<p class="font-mono text-xs uppercase tracking-widest text-muted mb-6 flex items-center gap-3">
  <span class="text-foreground/30">@</span>
  {company}
</p>
