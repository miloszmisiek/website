---
// GOOD
import { ProductsParallax } from "../components/products/ProductsParallax";
import { AnimatedSectionTitle } from "../components/arrayTitle/AnimatedSectionTitle";
import { FadeIn } from "../components/FadeIn";
import { FADE_DELAY } from "../styles/animations";
import { getProducts, getTranslations } from "../i18n";

const products = getProducts(Astro.currentLocale);
const t = getTranslations(Astro.currentLocale);
---

<section id="products" class="mb-24 short:mb-12">
  <div class="section-label">
    <span class="section-num">03</span>
    <AnimatedSectionTitle client:load text={t("section.products")} />
  </div>

  <FadeIn client:load delay={FADE_DELAY.sm} scrollTriggered noTranslate>
    <ProductsParallax client:load products={products} />
  </FadeIn>
</section>
