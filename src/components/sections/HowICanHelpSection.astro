---
import { FadeIn } from '../FadeIn';
import ArrayTitle from '../arrayTitle/ArrayTitle.astro';
import { useTranslations, type Locale } from '../../i18n';
import type { TechLogo } from '../../data/schema';
import techData from '../../data/tech-stack.json';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const allLogos = techData as TechLogo[];

const bySlug = (...slugs: string[]) =>
  slugs.map((s) => allLogos.find((l) => l.slug === s)).filter(Boolean) as TechLogo[];

const capabilities = [
  {
    index: '00',
    title: t('capabilities.product.title'),
    items: [
      t('capabilities.product.item1'),
      t('capabilities.product.item2'),
      t('capabilities.product.item3'),
    ],
    logos: [] as TechLogo[],
  },
  {
    index: '01',
    title: t('capabilities.frontend.title'),
    items: [
      t('capabilities.frontend.item1'),
      t('capabilities.frontend.item2'),
      t('capabilities.frontend.item3'),
    ],
    logos: bySlug('react', 'nextdotjs', 'astro', 'tailwindcss', 'framer'),
  },
  {
    index: '02',
    title: t('capabilities.fullstack.title'),
    items: [
      t('capabilities.fullstack.item1'),
      t('capabilities.fullstack.item2'),
      t('capabilities.fullstack.item3'),
    ],
    logos: bySlug('nodedotjs', 'graphql', 'mongodb', 'python', 'docker'),
  },
];
---

<FadeIn client:load delay={0.3} className="mb-32">
  <section id="capabilities">
    {/* Section Header */}
    <div class="section-label">
	<ArrayTitle translationKey={'section.howICanHelp'} lang={lang} />
    </div>

    {/* Capability Cards */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {capabilities.map((cap) => (
        <div class="card-base p-6 bg-white/[0.03] hover:bg-white/5 hover:border-border/80 transition-smooth flex flex-col">
          {/* Index */}
          <span class="block text-xs font-mono text-foreground/20 mb-4 tracking-widest">
            {cap.index}
          </span>

          {/* Title */}
          <h3 class="text-sm font-medium text-foreground tracking-tight mb-5">
            {cap.title}
          </h3>

          {/* Bullet list — flex-1 pushes logo strip to bottom */}
          <ul class="space-y-2.5 flex-1">
            {cap.items.map((item) => (
              <li class="flex items-start gap-2.5">
                <span class="text-foreground/20 select-none font-mono text-xs mt-0.5">—</span>
                <span class="text-sm text-muted leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>

          {/* Logo strip — only rendered when logos exist */}
          {cap.logos.length > 0 && (
            <div class="flex flex-wrap gap-3 mt-6 pt-4 border-t border-border/40">
              {cap.logos.map((logo) => (
                <img
                  src={`https://cdn.simpleicons.org/${logo.slug}/ffffff`}
                  alt=""
                  title={logo.name}
                  width="14"
                  height="14"
                  class="opacity-40"
                />
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</FadeIn>
