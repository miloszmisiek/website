---
import Button from "../components/button/Button.astro";
import { FadeIn } from "../components/FadeIn";
import { FADE_DELAY } from "../styles/animations";
import { getTranslations } from "../i18n";
import { TerminalTypewriter } from "../components/TerminalTypewriter";

const t = getTranslations(Astro.currentLocale);
// prettier-ignore
const M_LOGO = "█▀▄▀█\n█ ▀ █";
---

<section
  id="hero"
  class="pb-12 min-h-[calc(100svh-76px)] flex flex-col justify-start short:justify-center md2:pb-0 relative"
>
  <div class="flex-1 short:hidden" aria-hidden="true"></div>
  <FadeIn client:load delay={FADE_DELAY.xs}>
    <h1
      class="text-heading-xl mb-8 sm:mb-12 md:mb-16 short:mb-10 short:!text-[3.5rem] [@media(max-height:640px)]:!text-5xl [@media(max-height:640px)]:mb-8 [@media(max-height:640px)]:max-w-xl max-w-4xl lg:max-w-3xl text-transparent bg-clip-text text-gradient-heading [text-wrap:balance]"
    >
      {t("hero.typewriter")}
    </h1>
    <div
      class="grid grid-cols-1 md2:grid-cols-12 gap-8 md2:gap-12 text-muted font-light leading-relaxed text-sm md2:border-l-2 md2:border-line md2:pl-10 md2:ml-2"
    >
      <div class="md2:col-span-6 mlg:col-span-7 max-w-2xl pt-2">
        <p class="text-lg md:text-xl lg:text-2xl short:text-xl [@media(max-height:640px)]:text-lg text-foreground/75 leading-relaxed lg:leading-[1.4] mb-4 short:mb-2">
          <span class="text-foreground/50 font-mono mr-3" aria-hidden="true"
            >{"//"}</span
          >
          {t("hero.bio.first")}
        </p>
        <p class="text-lg md:text-xl lg:text-2xl short:text-xl [@media(max-height:640px)]:text-lg text-foreground/75 leading-relaxed lg:leading-[1.4] mb-8 sm:mb-10 short:mb-8">
          <span class="text-foreground/50 font-mono mr-3" aria-hidden="true"
            >{"//"}</span
          >
          {t("hero.bio.second")}
        </p>
        <div class="flex flex-wrap justify-start items-center gap-4">
          <span class="btn-radiate-wrap relative inline-flex">
            <Button
              href="#products"
              variant="primary"
              class="btn-radiate group"
            >
              {t("hero.cta.viewWork")}
            </Button>
          </span>
          <Button href="#contact" variant="secondary">
            {t("hero.cta.contact")}
          </Button>
        </div>

        {/* Compact terminal bar — mobile/tablet only */}
        <div class="md2:hidden mt-12 font-mono short:hidden" aria-hidden="true">
          <!-- Green line with badge, line visible on both sides -->
          <div class="flex items-center">
            <div class="flex-1 h-px bg-emerald-400"></div>
            <span
              class="px-2 py-0.5 bg-emerald-400 text-white text-micro tracking-wider font-medium shrink-0"
            >
              milosz-cli
            </span>
            <div class="w-6 h-px bg-emerald-400 shrink-0"></div>
          </div>
          <!-- Prompt line -->
          <div
            class="flex items-center gap-2 pb-2.5 text-foreground/80 text-label"
          >
            <span class="text-emerald-400">❯</span>
            <TerminalTypewriter
              client:load
              words={["frontend", "backend", "full-stack", "builder"]}
            />
          </div>
          <!-- Bottom green line (same structure as top) -->
          <div class="flex items-center">
            <div class="flex-1 h-px bg-emerald-400"></div>
          </div>
          <!-- Status footer -->
          <div class="flex items-center justify-between pt-2 text-caption">
            <div class="flex items-center gap-2 text-emerald-400">
              <div class="flex gap-0.5">
                <div class="w-1 h-3 bg-emerald-400"></div>
                <div class="w-1 h-3 bg-emerald-400"></div>
              </div>
              <span>plan mode on</span>
            </div>
            <span class="text-foreground/30 tracking-wider">Szczecin, PL</span>
          </div>
        </div>
      </div>

      {/* Terminal Window Stats */}
      <div class="md2:col-span-6 mlg:col-span-5 terminal-widget self-start hidden md2:block">
        <div
          class="terminal-frame relative overflow-hidden rounded-none font-mono text-caption sm:text-xs"
        >
          <!-- Title bar -->
          <div
            class="terminal-titlebar flex items-center justify-between px-4 py-3"
          >
            <div class="flex items-center gap-2" aria-hidden="true">
              <span class="terminal-dot w-2.5 h-2.5 rounded-full"></span>
              <span class="terminal-dot w-2.5 h-2.5 rounded-full"></span>
              <span class="terminal-dot w-2.5 h-2.5 rounded-full"></span>
            </div>
            <span
              class="text-micro font-mono text-foreground/45 tracking-widest"
              >milosz@dev:~</span
            >
          </div>

          <!-- Ambient screen glow -->
          <div class="terminal-glow pointer-events-none absolute inset-0"></div>

          <div class="relative p-0 flex flex-col text-muted">
            <div class="p-4 md:p-5 short:p-3">
              <!-- Main Content Box -->
              <fieldset
                class="terminal-fieldset rounded-none px-4 pb-5 pt-3 mb-1 short:pb-4 short:pt-3 short:mb-0"
              >
                <legend
                  class="px-2 text-[12px] text-foreground/45 tracking-wider"
                  >milosz-cli</legend
                >

                <div
                  class="flex flex-col items-center justify-center text-center space-y-4 short:space-y-2"
                >
                  <span class="text-foreground/90 font-medium tracking-wide"
                    >{t("hero.terminal.greeting")}</span
                  >

                  <div
                    class="text-emerald-400 leading-[1.15] whitespace-pre font-bold select-none text-[15px] text-center pt-2 pb-2 short:pt-1 short:pb-1"
                    aria-hidden="true"
                    set:text={M_LOGO}
                  />

                  <div
                    class="text-foreground/60 flex flex-col items-center text-micro tracking-wider uppercase pt-1"
                  >
                    <span>Node: Szczecin, PL · UTC+1</span>
                    <span class="lowercase mt-1 tracking-normal"
                      >~/workspace/portfolio</span
                    >
                  </div>
                </div>
              </fieldset>
            </div>

            <div class="flex flex-col">
              <!-- Top Divider -->
              <div class="terminal-divider h-px w-full"></div>

              <!-- Prompt Line -->
              <div
                class="flex items-center gap-2 px-4 md:px-5 py-3 short:py-2 text-foreground/80 font-mono text-label"
              >
                <span class="text-emerald-400">❯</span>
                <TerminalTypewriter
                  client:load
                  words={["frontend", "backend", "full-stack", "builder"]}
                />
              </div>

              <!-- Bottom Divider -->
              <div class="terminal-divider h-px w-full"></div>

              <!-- Footer / Mode Indicator -->
              <div
                class="flex items-center gap-2 px-4 md:px-5 py-3 short:py-2 text-emerald-400 font-mono text-caption"
              >
                <div class="flex gap-0.5">
                  <div class="w-1 h-3 bg-emerald-400"></div>
                  <div class="w-1 h-3 bg-emerald-400"></div>
                </div>
                <span>plan mode on</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </FadeIn>
  <div class="flex-[2] short:hidden" aria-hidden="true"></div>

  {/* Scroll indicator */}
  <div
    id="hero-scroll-indicator"
    class="flex md2:hidden justify-center pointer-events-none absolute bottom-8 inset-x-0 short:hidden"
    aria-hidden="true"
  >
    <div
      class="scroll-cue flex flex-col items-center gap-1.5 text-foreground/60 font-mono text-[9px] md:text-caption tracking-[0.25em] uppercase"
    >
      <span>scroll</span>
      <svg
        class="w-[10px] h-[14px] md:w-[13px] md:h-[18px]"
        viewBox="0 0 10 14"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M5 0v10M1 7l4 4 4-4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>
  </div>
</section>

<style>
  /* ── Terminal widget ── */
  .terminal-frame {
    background-color: rgb(var(--terminal-body-bg));
    border: 1px solid var(--terminal-border);
    box-shadow:
      0 0 0 1px rgba(230, 226, 221, 0.05),
      0 8px 30px rgba(0, 0, 0, 0.3),
      0 0 60px rgba(230, 226, 221, 0.03);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  .terminal-titlebar {
    background-color: var(--terminal-titlebar-bg);
    border-bottom: 1px solid var(--terminal-border);
  }

  .terminal-dot {
    background-color: rgb(var(--terminal-dot));
  }

  .terminal-glow {
    background: var(--terminal-glow);
  }

  .terminal-fieldset {
    border: 1px solid var(--terminal-fieldset);
  }

  .terminal-divider {
    background-color: var(--terminal-divider);
  }

  /* ── CTA button radiate animation (disabled) ── */
  /*
  @keyframes sonar-wave {
    0% {
      inset: -1px;
      opacity: 0.25;
      box-shadow:
        0 0 2px 0px rgb(var(--color-foreground)),
        inset 0 0 2px 0px rgb(var(--color-foreground));
    }
    100% {
      inset: -12px;
      opacity: 0;
      box-shadow:
        0 0 12px 2px rgb(var(--color-foreground)),
        inset 0 0 6px 2px rgb(var(--color-foreground));
    }
  }

  .btn-radiate {
    position: relative;
    z-index: 1;
  }

  .btn-radiate::before,
  .btn-radiate::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid rgb(var(--color-foreground));
    opacity: 0;
