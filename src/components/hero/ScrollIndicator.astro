---
---

<div
  id="hero-scroll-indicator"
  class="flex md2:hidden justify-center pointer-events-none absolute bottom-8 inset-x-0 short:hidden"
  aria-hidden="true"
>
  <div
    class="scroll-cue flex flex-col items-center gap-1.5 text-foreground/60 font-mono text-[9px] md:text-caption tracking-[0.25em] uppercase"
  >
    <span>scroll</span>
    <svg
      class="w-[10px] h-[14px] md:w-[13px] md:h-[18px]"
      viewBox="0 0 10 14"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M5 0v10M1 7l4 4 4-4"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </div>
</div>

<style>
  @keyframes scroll-nudge {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.5;
    }
    50% {
      transform: translateY(5px);
      opacity: 0.9;
    }
  }

  .scroll-cue {
    animation: scroll-nudge 2.2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue {
      animation: none;
    }
  }

  #hero-scroll-indicator {
    transition: opacity 0.4s ease;
  }
</style>

<script>
  const indicator = document.getElementById("hero-scroll-indicator");
  if (indicator) {
    window.addEventListener(
      "scroll",
      () => {
        indicator.style.opacity = "0";
      },
      { passive: true, once: true },
    );
  }
</script>
