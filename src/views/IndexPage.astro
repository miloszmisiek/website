---
import Layout from "../layouts/Layout.astro";
import { FadeIn } from "../components/FadeIn";
import Header from "../sections/Header.astro";
import ExperienceTimeline from "../sections/ExperienceTimeline.astro";
import PublicationsSection from "../sections/PublicationsSection.astro";
import FeaturedProductsSection from "../sections/FeaturedProductsSection.astro";
import ContactSection from "../sections/ContactSection.astro";
import Hero from "../sections/Hero.astro";
import "@fontsource/inter";
import "@fontsource/jetbrains-mono";
import "@fontsource/vt323";
import { getTranslations } from "../i18n";

const t = getTranslations(Astro.currentLocale);
---

<Layout title={t("layout.title")}>
  <!-- Navigation -->
  <Header />

  <div class="page-container pb-8 min-h-screen flex flex-col">
    <!-- Hero Section -->
    <main class="flex-grow">
      <Hero />
      <!-- Experience Timeline Section -->
      <ExperienceTimeline />

      <!-- Publications & Research Section -->
      <PublicationsSection />

      <!-- Featured Products Section -->
      <FeaturedProductsSection />

      <!-- Contact Section -->
      <ContactSection />
    </main>

    <FadeIn client:load delay={0.4}>
      <footer
        class="flex items-center text-xs font-mono text-muted py-8 border-t border-border/60 mt-auto"
      >
        <span class="tracking-widest"
          >© {new Date().getFullYear()} MILOSZ MISIEK</span
        >
      </footer>
    </FadeIn>
  </div>
</Layout>
