---
import Logo from '../logo/Logo.astro';
import NavLink from '../nav-links/NavLink.astro';
import LanguageSwitcher from '../LanguageSwitcher.astro';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { key: 'nav.work' as const, href: '#experience' },
  { key: 'nav.research' as const, href: '#publications' },
  { key: 'nav.contact' as const, href: '#contact' },
];
---

<header class="sticky top-0 z-[99999] bg-transparent flex justify-between items-center text-sm font-mono tracking-widest uppercase text-muted border-border pt-8 pb-6 mb-6 transition-[border-color] duration-300">
  <div class="flex items-center gap-4">
    <span class="text-foreground/40 hidden md:inline-block">~/</span>
    <Logo />
  </div>
  <nav class="flex items-center gap-8 md:gap-12">
    <div class="hidden md:flex items-center gap-8 border-r border-border/40 pr-8">
      {navLinks.map((link) => (
        <NavLink key={link.key} href={link.href} label={`[ ${t(link.key)} ]`} />
      ))}
    </div>
    <div class="flex items-center gap-4">
      <LanguageSwitcher lang={lang} />
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('header');
  const THRESHOLD = 80;

  function updateScrollState() {
    if (!header) return;
    if (window.scrollY > THRESHOLD) {
      header.setAttribute('data-scrolled', '');
    } else {
      header.removeAttribute('data-scrolled');
    }
  }

  window.addEventListener('scroll', updateScrollState, { passive: true });
  updateScrollState();
</script>

<style>
  header {
    background: transparent;
    transition: background 0.3s ease, backdrop-filter 0.3s ease;
  }
  header[data-scrolled] {
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
</style>
