---
import "../styles/global.css";
import vt323Url from "@fontsource/vt323/files/vt323-latin-400-normal.woff2?url";
import { LOCALE_META, defaultLocale, locales, type Locale } from "../i18n";
import {
  THEME,
  THEME_COLORS,
  THEME_STORAGE_KEY,
} from "../styles/theme-constants";

type Props = {
  title: string;
  description?: string;
};

const SEO = {
  ogType: "website",
  twitterCard: "summary_large_image",
  ogImagePath: "/og-milosz-full.png",
  defaultDescription:
    "Milosz Misiek — software engineer focused on performance and scalable systems.",
} as const;

const { title, description = SEO.defaultDescription } = Astro.props;

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const altLocale =
  locales.find((l) => l !== locale) ?? defaultLocale;

const toAbsolute = (path: string) => new URL(path, Astro.site).toString();

const altPath =
  locale === defaultLocale
    ? `/${altLocale}${Astro.url.pathname}`
    : Astro.url.pathname.replace(
        new RegExp(`^/${locale}(/|$)`),
        "/",
      );

const canonical = toAbsolute(Astro.url.pathname);
const ogImage = toAbsolute(SEO.ogImagePath);
const altHref = toAbsolute(altPath);
const defaultHref = toAbsolute("/");
---

<!doctype html>
<html lang={locale} class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={THEME_COLORS[THEME.DARK]} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link rel="alternate" hreflang={altLocale} href={altHref} />
    <link rel="alternate" hreflang="x-default" href={defaultHref} />

    <meta property="og:type" content={SEO.ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={LOCALE_META[locale].og} />

    <meta name="twitter:card" content={SEO.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href={vt323Url}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Anti-FOUC: apply stored theme before first paint. Must be inline and
         synchronous so the data-theme attribute is set before stylesheets resolve. -->
    <script
      is:inline
      define:vars={{
        STORAGE_KEY: THEME_STORAGE_KEY,
        DARK: THEME.DARK,
        LIGHT: THEME.LIGHT,
      }}
    >
      (() => {
        if ("scrollRestoration" in history)
          history.scrollRestoration = "manual";
        const stored = localStorage.getItem(STORAGE_KEY);
        const prefersDark = matchMedia("(prefers-color-scheme: dark)").matches;
        const theme =
          stored === DARK || stored === LIGHT
            ? stored
            : prefersDark
              ? DARK
              : LIGHT;
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <!-- 90s Retro Easter Egg trigger: Konami code (↑↑↓↓←→←→BA) + persistence.
         Self-contained, no DOM mutation unless the sequence matches. -->
    <script is:inline>
      (() => {
        const SEQ = [
          "ArrowUp", "ArrowUp", "ArrowDown", "ArrowDown",
          "ArrowLeft", "ArrowRight", "ArrowLeft", "ArrowRight",
          "b", "a",
        ];
        const path = location.pathname;
        const isRetro = path === "/retro" || path === "/pl/retro";
        const isPl = document.documentElement.lang === "pl";
        const retroPath = isPl ? "/pl/retro" : "/retro";

        try {
          if (!isRetro && localStorage.getItem("retro_mode") === "on") {
            location.replace(retroPath);
            return;
          }
        } catch (e) {}

        let i = 0;
        addEventListener("keydown", (e) => {
          const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
          if (key === SEQ[i]) {
            i++;
            if (i === SEQ.length) {
              try { localStorage.setItem("retro_mode", "on"); } catch (e) {}
              location.href = retroPath;
            }
          } else {
            i = key === SEQ[0] ? 1 : 0;
          }
        });
      })();
    </script>

    <!-- Stable hash-anchor scrolling: after fonts and images load, re-scroll to
         #target so font-swap reflow and image layout shift do not leave the
         section offset on reload. -->
    <script is:inline>
      (() => {
        if (!location.hash) return;
        const reanchor = () => {
          const el = document.querySelector(location.hash);
          if (el) el.scrollIntoView({ behavior: "instant", block: "start" });
        };
        const onReady = () => {
          const fontsReady =
            document.fonts && document.fonts.ready
              ? document.fonts.ready
              : Promise.resolve();
          const loaded =
            document.readyState === "complete"
              ? Promise.resolve()
              : new Promise((r) =>
                  window.addEventListener("load", r, { once: true }),
                );
          Promise.all([fontsReady, loaded]).then(() =>
            requestAnimationFrame(reanchor),
          );
        };
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", onReady, { once: true });
        } else {
          onReady();
        }
      })();
    </script>
  </head>
  <body
    class="relative selection:bg-foreground selection:text-background overflow-x-hidden"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-skip focus:px-4 focus:py-2 focus:bg-foreground focus:text-background focus:font-mono focus:text-xs focus:tracking-technical focus:uppercase focus:outline-none focus:ring-2 focus:ring-foreground focus:ring-offset-2"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
