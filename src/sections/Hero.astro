    pointer-events: none;
    z-index: -1;
  }

  .btn-radiate::after {
    animation-delay: 1.5s;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-radiate::before,
    .btn-radiate::after {
      animation: none;
      display: none;
    }
  }
  */

  /* ── Scroll indicator ── */
  @keyframes scroll-nudge {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.5;
    }
    50% {
      transform: translateY(5px);
      opacity: 0.9;
    }
  }

  .scroll-cue {
    animation: scroll-nudge 2.2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue {
      animation: none;
    }
  }

  #hero-scroll-indicator {
    transition: opacity 0.4s ease;
  }
</style>

<script>
  // Ensure page starts at top on every load
  window.scrollTo({ top: 0, behavior: "instant" });

  // Hide scroll indicator on first scroll
  const indicator = document.getElementById("hero-scroll-indicator");
  if (indicator) {
    window.addEventListener(
      "scroll",
      () => {
        indicator.style.opacity = "0";
      },
      { passive: true, once: true },
    );
  }

  // All screens: first wheel/touch scroll snaps directly to the experience section
  let userInitiatedScroll = false;

  const cancelSnap = () => {
    window.removeEventListener("scroll", snapToExperience);
  }

  window.addEventListener(
    "wheel",
    () => {
      userInitiatedScroll = true;
    },
    { passive: true, once: true },
  );
  window.addEventListener(
    "touchmove",
    () => {
      userInitiatedScroll = true;
    },
    { passive: true, once: true },
  );

  // Any anchor link click disables the snap entirely
  document.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener("click", cancelSnap, { once: true });
  });

  const snapToExperience = () => {
    if (!userInitiatedScroll) return;

    // Abort snap scroll on very short screens (let the user scroll naturally)
    if (window.innerHeight <= 800) {
      cancelSnap();
      return;
    }

    if (window.scrollY > 0) {
      cancelSnap();
      const experience = document.getElementById("experience");
      if (experience) {
        experience.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
  }
  window.addEventListener("scroll", snapToExperience, { passive: true });
</script>
