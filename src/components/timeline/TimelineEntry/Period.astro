---
type Props = {
  start: string;
  end: string;
  presentLabel: string;
  duration?: string;
};

const { start, end, presentLabel, duration } = Astro.props;

const startYear = start.split("-")[0];
const endYear =
  end.toLowerCase() === "present" ? presentLabel : end.split("-")[0];
---

<div
  class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-3 gap-2"
>
  <span class="text-label tracking-[0.3em] uppercase">
    {startYear}
    <span class="text-foreground/50 mx-1">{`->`}</span>
    {endYear}
  </span>
  {
    duration && (
      <span class="hidden sm:inline text-[10px] font-mono text-muted uppercase tracking-widest px-2 py-0.5">
        {duration}
      </span>
    )
  }
</div>
