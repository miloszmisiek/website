---
import type { TimelineEntry as TimelineEntryType } from '../../data/schema';
import { useTranslations, type Locale } from '../../i18n';

interface Props {
  entry: TimelineEntryType;
  index: number;
  lang: Locale;
}

const { entry, index, lang } = Astro.props;
const t = useTranslations(lang);
const isWork = entry.type === 'work';
const isAcademic = entry.type === 'academic';
---

<div class="group relative pl-8 md:pl-10 lg:pl-12 transition-smooth">
  {/* Timeline Dot */}
  <div class="absolute -left-2 md:-left-2.5 lg:-left-3 top-2 md:top-3 w-2 md:w-2.5 lg:w-3 h-2 md:h-2.5 lg:h-3 rounded-full border-2 border-border group-hover:border-foreground transition-smooth bg-background"></div>

  {/* Entry Content */}
  <div class="mb-12 md:mb-16 lg:mb-20 last:mb-0">
    {/* Period and Duration */}
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-2">
      <span class="text-label">
        {entry.period.start.split('-')[0]} - {entry.period.end === 'present' ? t('timeline.present') : entry.period.end.split('-')[0]}
      </span>
      {entry.duration && <span class="text-label text-muted/70">{entry.duration}</span>}
    </div>

    {/* Role and Company */}
    <h3 class="text-heading-md mb-1">
      {entry.role}
    </h3>
    <p class="text-sm italic text-muted mb-3">{entry.company}</p>

    {/* Focus Area */}
    {entry.focus && (
      <p class="text-xs font-mono tracking-widest text-muted mb-3 uppercase">
        {entry.focus}
      </p>
    )}

    {/* Description */}
    <p class="text-body mb-4">
      {entry.description}
    </p>

    {/* Highlights */}
    {entry.highlights && entry.highlights.length > 0 && (
      <ul class="space-y-2 mb-4">
        {entry.highlights.map((highlight) => (
          <li class="text-body flex gap-3">
            <span class="text-muted flex-shrink-0">•</span>
            <span>{highlight}</span>
          </li>
        ))}
      </ul>
    )}

    {/* Technologies */}
    {entry.technologies && entry.technologies.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {entry.technologies.map((tech, i) => (
          <span key={tech} class="text-label">
            {tech}
            {i < entry.technologies.length - 1 ? <span class="text-muted"> · </span> : ''}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
