---
import type { TimelineEntry as TimelineEntryType } from '../../data/schema';
import { useTranslations, type Locale } from '../../i18n';
import { TimelineTechStack } from './TimelineTechStack';

interface Props {
  entry: TimelineEntryType;
  index: number;
  lang: Locale;
}

const { entry, index, lang } = Astro.props;
const t = useTranslations(lang);
const isWork     = entry.type === 'work';
const isAcademic = entry.type === 'academic';

// Branch name from company
const branchSlug = entry.company
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-|-$/g, '');
const branchPrefix = isWork ? 'feat' : 'edu';
const branchName   = `${branchPrefix}/${branchSlug}`;

// Short commit hash from id
const shortHash = entry.id.replace(/[^a-z0-9]/g, '').slice(0, 7).padEnd(7, '0');

// Highlights: max 3
const MAX_HIGHLIGHTS    = 3;
const visibleHighlights = entry.highlights?.slice(0, MAX_HIGHLIGHTS) ?? [];
---

<div class="timeline-entry relative pl-12 md:pl-16 transition-smooth mb-24 py-6 -my-6 rounded-lg border border-transparent">
  {/* Commit node */}
  <div class:list={["node", isWork ? "node--work" : "node--academic"]}>
    <div class:list={["node-inner", isWork ? "node-inner--work" : "node-inner--academic"]}></div>
  </div>

  {/* Horizontal branch connector */}
  <div class="branch-line"></div>

    <div class="relative z-10">

    {/* Git ref row */}
    <div class="git-ref mb-6">
      <span class:list={["ref-hash", isWork ? "ref-hash--work" : "ref-hash--academic"]}>{shortHash}</span>
      <span class="ref-sep ml-2 mr-2">--&gt;</span>
      <span class="ref-branch border border-border/40 bg-neutral-900/40 px-2 py-0.5 rounded-sm">{branchName}</span>
      {index === 0 && <span class="ref-head ml-3 tracking-[0.2em]">HEAD</span>}
    </div>

    {/* Period */}
    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-3 gap-2">
      <span class="text-label text-muted/60 tracking-[0.3em] uppercase">
        {entry.period.start.split('-')[0]} <span class="text-foreground/30 mx-1">-></span> {entry.period.end === 'present' ? t('timeline.present') : entry.period.end.split('-')[0]}
      </span>
      {entry.duration && <span class="text-[10px] font-mono text-muted/40 uppercase tracking-widest border border-border/30 px-2 py-0.5">{entry.duration}</span>}
    </div>

    <h3 class="text-heading-md mb-2">{entry.role}</h3>
    <p class="font-mono text-xs uppercase tracking-widest text-muted/80 mb-6 flex items-center gap-3">
      <span class="text-foreground/30">@</span>
      {entry.company}
    </p>

    {entry.focus && (
      <p class="text-[10px] font-mono tracking-[0.2em] text-foreground/50 mb-4 uppercase border-l-2 border-foreground/20 pl-3">
        <span class="text-muted/30 mr-2">{"//"}</span>{entry.focus}
      </p>
    )}

    {visibleHighlights.length > 0 && (
      <ul class="space-y-3 mb-8">
        {visibleHighlights.map((h) => (
          <li class="text-body text-muted/80 flex gap-4 leading-relaxed">
            <span class="text-foreground/20 flex-shrink-0 font-mono select-none mt-1">-&gt;</span>
            <span>{h}</span>
          </li>
        ))}
      </ul>
    )}

    {entry.technologies && entry.technologies.length > 0 && (
      <TimelineTechStack 
        client:visible 
        technologies={entry.technologies} 
        maxTech={4} 
      />
    )}
  </div>
</div>

<style>
  /* Commit node */
  .node {
    position: absolute;
    left: -7px;
    top: 36px; /* adjusted for padding */
    width: 15px;
    height: 15px;
    border-radius: 0; /* Make it a square for programming feel */
    border: 2px solid var(--color-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-background);
    transition: transform 0.3s ease, border-radius 0.3s ease;
    z-index: 10;
  }
  
  :global(.timeline-entry.is-active) .node { 
    transform: scale(1.15) rotate(45deg); 
  }

  .node--work {
    border-color: var(--color-info);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-info), transparent 90%);
  }
  .node--academic {
    border-color: var(--color-success);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-success), transparent 90%);
  }

  .node-inner { 
    width: 5px; 
    height: 5px; 
    transition: transform 0.3s ease;
  }
  
  :global(.timeline-entry.is-active) .node-inner {
    transform: scale(0.5);
  }
  
  .node-inner--work    { background-color: var(--color-info); }
  .node-inner--academic { background-color: var(--color-success); }

  /* Horizontal branch connector from node to content */
  .branch-line {
    position: absolute;
    left: 8px;
    top: 43px; /* adjusted for padding */
    width: calc(3rem - 8px); /* connects from node to pl-12 (3rem) */
    height: 1px;
    background-color: var(--color-border);
    opacity: 0.5;
    transition: width 0.3s ease, opacity 0.3s ease, background-color 0.3s ease;
  }
  
  @media (min-width: 768px) {
    .branch-line {
      width: calc(4rem - 8px); /* pl-16 is 4rem */
    }
  }

  :global(.timeline-entry.is-active) .branch-line {
    opacity: 1;
    background-color: var(--color-foreground);
    background-image: repeating-linear-gradient(to right, var(--color-foreground) 0, var(--color-foreground) 4px, transparent 4px, transparent 8px);
  }

  /* Git ref row */
  .git-ref {
    display: flex;
    align-items: center;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    font-size: 0.65rem;
    color: var(--color-muted);
    select: none;
  }

  .ref-hash { opacity: 0.8; letter-spacing: 0.08em; }
  .ref-hash--work    { color: var(--color-info); }
  .ref-hash--academic { color: var(--color-success); }

  .ref-sep    { opacity: 0.2; font-size: 0.55rem; }
  .ref-branch { opacity: 0.7; letter-spacing: 0.05em; }

  .ref-head {
    font-size: 0.55rem;
    padding: 1px 5px;
    border-radius: 2px;
    background-color: color-mix(in srgb, var(--color-info), transparent 85%);
    color: var(--color-info);
    border: 1px solid color-mix(in srgb, var(--color-info), transparent 70%);
  }

  /* Tech overflow badge */
  :global(.tech-overflow) {
    font-size: 0.55rem;
    padding: 2px 6px;
    border-radius: 2px;
    border: 1px dashed var(--color-border);
    color: var(--color-muted);
    opacity: 0.8;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
    letter-spacing: 0.1em;
  }
</style>
