---
import Logo from "../components/logo/Logo.astro";
import NavLink from "../components/nav-links/NavLink.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import { getTranslations } from "../i18n";

const t = getTranslations(Astro.currentLocale);

const navLinks = [
  { key: "nav.research" as const, href: "#publications" },
  { key: "nav.work" as const, href: "#products" },
  { key: "nav.contact" as const, href: "#contact" },
];
---

<header
  class="sticky top-0 z-[99999] bg-transparent text-sm font-mono tracking-widest uppercase text-muted border-border pt-4 pb-4 transition-[border-color] duration-300"
>
  <div class="page-container flex justify-between items-center">
    <div class="flex items-center gap-4">
      <span class="text-foreground/55 hidden md:inline-block">~/</span>
      <Logo />
    </div>
    <nav class="flex items-center gap-6 md:gap-8">
      <div class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <NavLink href={link.href} label={t(link.key)} />
          ))
        }
      </div>

      <div class="hidden md:block w-[1px] h-6 bg-foreground/20 mx-2"></div>

      <div class="flex items-center gap-3">
        <ThemeSwitcher />
        <LanguageSwitcher />
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector("header");
  const THRESHOLD = 40;

  const updateScrollState = () => {
    if (!header) return;
    if (window.scrollY > THRESHOLD) {
      header.setAttribute("data-scrolled", "");
    } else {
      header.removeAttribute("data-scrolled");
    }
  };

  window.addEventListener("scroll", updateScrollState, { passive: true });
  updateScrollState();
</script>

<style>
  header {
    background: rgb(var(--color-hero-bg));
    transition:
      background 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  /* Dark mode scrolled */
  :root[data-theme="dark"] header[data-scrolled],
  header[data-scrolled] {
    background: rgb(var(--color-background));
    backdrop-filter: none;
    /* border-bottom: 1px solid rgba(230, 226, 221, 0.06); */
  }

  /* Light mode scrolled — warm paper */
  :root[data-theme="light"] header[data-scrolled] {
    background: rgba(248, 245, 239, 0.85);
    backdrop-filter: blur(12px);
    /* border-bottom: 1px solid rgba(26, 21, 16, 0.1); */
  }
</style>
