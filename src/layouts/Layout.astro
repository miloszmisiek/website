---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang={Astro.currentLocale} style="color-scheme: dark;">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Milosz Misiek Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="selection:bg-foreground selection:text-background">
    <slot />
  </body>
</html>
