---
type Props = {
  retroHref: string;
};

const { retroHref } = Astro.props;
---

<a
  href={retroHref}
  id="retro-link"
  aria-label="Enter retro mode"
  title="Enter retro mode (1996 edition)"
  class="ml-auto inline-flex items-center gap-1.5 text-muted hover:text-foreground transition-colors tracking-widest"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 16 16"
    width="14"
    height="14"
    fill="none"
    stroke="currentColor"
    stroke-width="1.25"
    aria-hidden="true"
  >
    <rect x="1.5" y="1.5" width="13" height="13" rx="0.5"></rect>
    <rect x="3.5" y="1.5" width="9" height="5"></rect>
    <rect x="9.5" y="2.5" width="2" height="3" fill="currentColor"></rect>
    <rect x="4" y="9" width="8" height="5"></rect>
    <line x1="5.5" y1="10.5" x2="10.5" y2="10.5"></line>
    <line x1="5.5" y1="12" x2="10.5" y2="12"></line>
  </svg>
  <span>RETRO_MODE.EXE</span>
</a>
