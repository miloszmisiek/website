---
import Layout from "../layouts/Layout.astro";
import { FadeIn } from "../components/FadeIn";
import { FADE_DELAY } from "../styles/animations";
import Header from "../sections/Header.astro";
import ExperienceTimeline from "../sections/ExperienceTimeline.astro";
import PublicationsSection from "../sections/PublicationsSection.astro";
import FeaturedProductsSection from "../sections/FeaturedProductsSection.astro";
import ContactSection from "../sections/ContactSection.astro";
import Hero from "../sections/Hero.astro";
import "@fontsource/inter";
import "@fontsource/jetbrains-mono";
import "@fontsource/vt323";
import { getTranslations } from "../i18n";

const t = getTranslations(Astro.currentLocale);
const retroHref = Astro.currentLocale === "pl" ? "/pl/retro" : "/retro";
---

<Layout title={t("layout.title")}>
  <!-- Header lives outside hero-zone so sticky works across the full page -->
  <Header />

  <!-- Hero zone: full-viewport-width area covering just the hero section -->
  <div class="hero-zone">
    <div class="page-container">
      <Hero />
    </div>
  </div>

  <div class="page-container">
    <main id="main-content">
      <!-- Experience Timeline Section -->
      <ExperienceTimeline />

      <!-- Publications & Research Section -->
      <PublicationsSection />

      <!-- Featured Products Section -->
      <FeaturedProductsSection />

      <!-- Contact Section -->
      <ContactSection />
    </main>
  </div>

  <!-- Footer zone: mirrors hero-zone with fade at top -->
  <div class="footer-zone relative z-10">
    <div class="page-container">
      <FadeIn client:load delay={FADE_DELAY.md}>
        <footer class="flex items-center gap-3 text-xs font-mono text-muted py-8">
          <picture>
            <source srcset="/profile.webp" type="image/webp" />
            <img
              src="/profile.png"
              alt="Milosz Misiek"
              width="32"
              height="32"
              loading="lazy"
              decoding="async"
              class="rounded-full object-cover w-8 h-8 grayscale contrast-110 hover:grayscale-0 hover:contrast-100 transition-[filter] duration-500 ring-1 ring-muted/30 hover:ring-muted/60"
            />
          </picture>
          <span class="tracking-widest"
            >© {new Date().getFullYear()} MILOSZ MISIEK</span
          >
          <a
            href={retroHref}
            id="retro-link"
            aria-label="Enter retro mode"
            title="Enter retro mode (1996 edition)"
            class="ml-auto inline-flex items-center gap-1.5 text-muted hover:text-foreground transition-colors tracking-widest"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 16 16"
              width="14"
              height="14"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              aria-hidden="true"
            >
              <rect x="1.5" y="1.5" width="13" height="13" rx="0.5" />
              <rect x="3.5" y="1.5" width="9" height="5" />
              <rect x="9.5" y="2.5" width="2" height="3" fill="currentColor" />
              <rect x="4" y="9" width="8" height="5" />
              <line x1="5.5" y1="10.5" x2="10.5" y2="10.5" />
              <line x1="5.5" y1="12" x2="10.5" y2="12" />
            </svg>
            <span>RETRO_MODE.EXE</span>
          </a>
        </footer>
        <script is:inline>
          (function () {
            var link = document.getElementById("retro-link");
            if (!link) return;
            link.addEventListener("click", function () {
              try {
                localStorage.setItem("retro_mode", "on");
              } catch (e) {}
            });
          })();
        </script>
      </FadeIn>
    </div>
  </div>
</Layout>
