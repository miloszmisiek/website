---
import Logo from "../components/logo/Logo.astro";
import NavLink from "../components/nav-links/NavLink.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import MobileMenu from "../components/MobileMenu.astro";
import { getTranslations } from "../i18n";

const t = getTranslations(Astro.currentLocale);

const navLinks = [
  { key: "nav.research" as const, href: "#publications" },
  { key: "nav.work" as const, href: "#products" },
  { key: "nav.contact" as const, href: "#contact" },
];

const translatedLinks = navLinks.map((link) => ({
  label: t(link.key),
  href: link.href,
}));
---

<header
  class="scroll-bg sticky top-0 z-[99999] text-sm font-mono tracking-widest uppercase text-muted border-border pt-4 pb-4 will-change-transform data-[hidden]:-translate-y-full"
>
  <div class="page-container flex justify-between items-center">
    <div class="flex items-center gap-4">
      <span class="text-foreground/55 hidden md:inline-block">~/</span>
      <Logo />
    </div>
    <nav class="flex items-center gap-6 md:gap-8">
      <div class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <NavLink href={link.href} label={t(link.key)} />
          ))
        }
      </div>

      <div class="hidden md:block w-[1px] h-6 bg-foreground/20 mx-2"></div>

      <div class="flex items-center gap-3">
        <ThemeSwitcher />
        <LanguageSwitcher />
        <MobileMenu links={translatedLinks} />
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector("header");
  const mobileMenu = document.getElementById("mobile-menu");
  const THRESHOLD = 40;
  const HIDE_DELTA = 8;

  let lastY = window.scrollY;
  let ticking = false;

  const setHeaderHeightVar = () => {
    if (!header) return;
    document.documentElement.style.setProperty(
      "--header-height",
      `${header.offsetHeight}px`,
    );
  };
  setHeaderHeightVar();
  window.addEventListener("resize", setHeaderHeightVar, { passive: true });

  // Initial hash load: the browser jumps before fonts/images/hydration settle,
  // so the target keeps moving after we land on it. Wait for full load, then
  // compute the offset ourselves and scroll once.
  if (location.hash) {
    const hash = location.hash;
    if ("scrollRestoration" in history) history.scrollRestoration = "manual";

    const scrollToHash = () => {
      const target = document.querySelector(hash);
      if (!(target instanceof HTMLElement)) return;
      const headerH = header?.offsetHeight ?? 76;
      const top =
        target.getBoundingClientRect().top + window.scrollY - headerH - 16;
      window.scrollTo({ top, behavior: "smooth" });
    };

    const onReady = () => {
      const fonts = (document as any).fonts?.ready ?? Promise.resolve();
      fonts.then(() => {
        requestAnimationFrame(() => requestAnimationFrame(scrollToHash));
      });
    };

    if (document.readyState === "complete") {
      onReady();
    } else {
      window.addEventListener("load", onReady, { once: true });
    }
  }

  const updateScrollState = () => {
    if (!header) return;

    const y = window.scrollY;
    const delta = y - lastY;

    if (y > THRESHOLD) {
      header.setAttribute("data-scrolled", "");
      mobileMenu?.setAttribute("data-scrolled", "");
    } else {
      header.removeAttribute("data-scrolled");
      mobileMenu?.removeAttribute("data-scrolled");
    }

    const menuOpen = mobileMenu?.hasAttribute("data-open");
    if (!menuOpen && y > THRESHOLD && Math.abs(delta) > HIDE_DELTA) {
      if (delta > 0) {
        header.setAttribute("data-hidden", "");
      } else {
        header.removeAttribute("data-hidden");
      }
    } else if (y <= THRESHOLD) {
      header.removeAttribute("data-hidden");
    }

    lastY = y;
    ticking = false;
  };

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        requestAnimationFrame(updateScrollState);
        ticking = true;
      }
    },
    { passive: true },
  );
  updateScrollState();
</script>
