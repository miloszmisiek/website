---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../i18n';

const currentLang = Astro.currentLocale as Locale;
const otherLang: Locale = currentLang === 'en' ? 'pl' : 'en';
const switchUrl = getRelativeLocaleUrl(otherLang, '/');
---

<a
  href={switchUrl}
  class="text-xs font-mono tracking-widest text-muted hover:text-foreground transition-colors border border-border/50 px-2 py-1 rounded hover:border-border"
  aria-label={`Switch to ${otherLang === 'en' ? 'English' : 'Polish'}`}
>
  {otherLang.toUpperCase()}
</a>
