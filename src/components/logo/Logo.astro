<a
  href="/"
  class="inline-flex select-none cursor-pointer font-nav text-2xl leading-none tracking-wide"
  aria-label="milosz misiek — home"
>
  {/* Mobile: block-art M */}
  <span
    class="md:hidden font-mono text-xs leading-[1.15] whitespace-pre text-foreground select-none"
    aria-hidden="true"
    set:text={"█▀▄▀█\n█ ▀ █"}
  />

  {/* Desktop: milosz.misiek */}
  <span class="hidden md:inline-flex items-baseline">
    <span class="text-foreground">milosz</span>
    <span class="text-muted">.</span>
    <span class="text-foreground">misiek</span>
  </span>
</a>

