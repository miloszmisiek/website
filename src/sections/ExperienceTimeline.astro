---
import { FadeIn } from '../components/FadeIn';
import TimelineEntry from '../components/timeline/TimelineEntry/index.astro';
import TimelineAnimator from '../components/timeline/TimelineAnimator';
import ArrayTitle from '../components/arrayTitle/ArrayTitle.astro';
import type { TimelineEntry as TimelineEntryType } from '../data/schema';
import type { Locale } from '../i18n';
import enData from '../data/experience.en.json';
import plData from '../data/experience.pl.json';

const lang = Astro.currentLocale as Locale;
const experience = (lang === 'pl' ? plData : enData) as TimelineEntryType[];
---

<FadeIn client:load delay={0.3} className="mb-32">
  <section id="experience">

    {/* Section Header */}
    <div class="section-label">
      <ArrayTitle translationKey={'section.experience'} />
    </div>

    {/* Timeline */}
    <div class="timeline-container">
      <div class="trunk"></div>
      <span class="trunk-label">* main</span>

      <TimelineAnimator client:load items={experience} staggerDelay={0.12}>
        {experience.map((entry, index) => (
          <TimelineEntry entry={entry} index={index} />
        ))}
      </TimelineAnimator>
    </div>

  </section>
</FadeIn>

<script>
  function setupTimelineObserver() {
    const entries = document.querySelectorAll('.timeline-entry');
    if (!entries.length) return;

    const observer = new IntersectionObserver((entriesList) => {
      entriesList.forEach(entry => {
        entry.target.classList.toggle('is-active', entry.isIntersecting);
      });
    }, {
      rootMargin: '-30% 0px -40% 0px',
      threshold: 0
    });

    entries.forEach(entry => observer.observe(entry));
  }

  // Run on initial load
  setupTimelineObserver();
  
  // If using view transitions, ensure it runs on navigation
  document.addEventListener('astro:page-load', setupTimelineObserver);
</script>

<style>
  .timeline-container {
    position: relative;
    margin-left: 1rem;
  }

  @media (min-width: 768px)  { .timeline-container { margin-left: 2rem; } }
  @media (min-width: 1024px) { .timeline-container { margin-left: 3rem; } }

  /* Dashed vertical trunk */
  .trunk {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background-image: repeating-linear-gradient(
      to bottom,
      var(--color-border) 0px,
      var(--color-border) 6px,
      transparent 6px,
      transparent 12px
    );
  }

  /* * main label above trunk */
  .trunk-label {
    position: absolute;
    left: 6px;
    top: -20px;
    font-family: theme('fontFamily.mono-system');
    font-size: 0.62rem;
    color: var(--color-muted);
    opacity: 0.45;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
</style>
