---
import type { TimelineEntry as TimelineEntryType } from "../../../data/schema";
import { ExperienceTypeEnum } from "../../../data/types";
import { getTranslations } from "../../../i18n";
import { TimelineTechStack } from "../TimelineTechStack";
import CommitNode from "./CommitNode.astro";
import GitRef from "./GitRef.astro";
import Period from "./Period.astro";
import EntryHeader from "./EntryHeader.astro";
import EntryFocus from "./EntryFocus.astro";
import Highlights from "./Highlights.astro";

const MAX_HIGHLIGHTS = 3;

type Props = {
  entry: TimelineEntryType;
  index: number;
};

const { entry, index } = Astro.props;
const t = getTranslations(Astro.currentLocale);

const {
  period: { start, end },
  type,
  duration,
  role,
  company,
  highlights = [],
  technologies,
  focus,
} = entry;
const isWork = type === ExperienceTypeEnum.Work;
const visibleHighlights = highlights?.slice(0, MAX_HIGHLIGHTS);
---

<div
  class="timeline-entry relative pl-10 md:pl-12 lg:pl-16 transition ease-in-out duration-300 mb-16 md:mb-24 py-6 -my-6 rounded-none border border-transparent"
>
  <CommitNode isWork={isWork} />

  <div class="relative z-10">
    <GitRef entry={entry} isWork={isWork} isHead={index === 0} />

    <Period
      start={start}
      end={end}
      presentLabel={t("timeline.present")}
      duration={duration}
    />

    <EntryHeader role={role} company={company} />

    {focus && <EntryFocus focus={focus} />}

    {
      visibleHighlights.length > 0 && (
        <Highlights highlights={visibleHighlights} />
      )
    }

    {
      technologies.length > 0 && (
        <TimelineTechStack
          client:visible
          technologies={technologies}
          maxTech={4}
        />
      )
    }
  </div>
</div>

<style>
  :global(.tech-overflow) {
    font-size: 0.55rem;
    padding: 2px 6px;
    border-radius: 0;
    border: 1px dashed var(--color-line);
    color: var(--color-muted);
    opacity: 1;
    font-family: theme("fontFamily.mono-system");
    letter-spacing: 0.1em;
  }
</style>
