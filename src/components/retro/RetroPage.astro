---
import { getExperience, getPublications, getProducts } from "../../i18n/data";
import { getTranslations } from "../../i18n/translations";
import type { Locale } from "../../i18n/config";

type Props = {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const experience = getExperience(locale);
const publications = getPublications(locale);
const products = getProducts(locale);

const homeHref = locale === "pl" ? "/pl/" : "/";
const year = new Date().getFullYear();
const buildDate = new Date().toISOString().slice(0, 10);

const newestExpYear = experience.reduce((max, e) => {
  const startYear = parseInt(e.period.start.slice(0, 4), 10);
  return startYear > max ? startYear : max;
}, 0);

const isOngoing = (e: typeof experience[number]) => e.period.end === "present";

const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const formatPeriod = (ym: string) => {
  const [y, m] = ym.split("-");
  const mi = parseInt(m ?? "0", 10) - 1;
  return mi >= 0 && mi < 12 ? `${MONTHS[mi]} ${y}` : ym;
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MILOSZ MISIEK | SOFTWARE ENGINEER (1996 EDITION)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&display=swap" />
    <link rel="stylesheet" href="/retro.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="dialup" id="dialup"><div class="dialup-bar"></div></div>

    <div class="page">
      <div class="page-titlebar">
        <span>MILOSZ.EXE — Netscape Navigator 4.0</span>
        <div class="page-titlebar-controls">
          <span class="page-titlebar-btn" aria-hidden="true">_</span>
          <span class="page-titlebar-btn" aria-hidden="true">□</span>
          <button class="page-titlebar-btn page-titlebar-close" id="exit-retro" type="button" aria-label={t("retro.close")} title={t("retro.close.tooltip")} data-home={homeHref}>✕</button>
        </div>
      </div>

      <div class="page-inner">
      <div class="center">
        <h1>~ MILOSZ MISIEK ~</h1>
        <h3 class="mono">{t("retro.hero.subtitle")}</h3>
      </div>

      <div class="retro-nav">
        <a href={homeHref}>{t("retro.nav.home")}</a> |
        <a href="#research">{t("retro.nav.research")}</a> |
        <a href="#work">{t("retro.nav.work")}</a> |
        <a href="#products">{t("retro.nav.products")}</a> |
        <a href="#contact">{t("retro.nav.contact")}</a> |
        <a href={locale === "pl" ? "/pl/guestbook" : "/guestbook"}>{t("retro.guestbook.heading")}</a>
      </div>

      <div class="badges">
        <span class="bevel-in">HTML 3.2 Approved</span>
        <span class="bevel-in">Powered by Coffee &amp; Dial-Up</span>
        <button id="midi-toggle" type="button" aria-pressed="false">♪ MIDI: OFF</button>
      </div>

      <marquee scrollamount="6">{t("retro.marquee")}</marquee>

      <hr />

      <!-- HERO / BIO -->
      <table width="100%" cellpadding="6" cellspacing="2" border="1" class="hero-card">
        <tr>
          <td width="120" align="center">
            <img
              src="/retro_milosz_specs.webp"
              alt="[Photo of Milosz Misiek]"
              width="100"
              height="100"
              loading="eager"
              fetchpriority="high"
            />
          </td>
          <td>
            <h2>{t("retro.about.heading")}</h2>
            <p><b>{t("retro.about.name")}</b> Milosz Misiek</p>
            <p><b>{t("retro.about.occupation")}</b> {t("retro.about.occupationValue")}</p>
            <ul>
              <li>{t("hero.bio.first")}</li>
              <li>{t("hero.bio.second")}</li>
            </ul>
          </td>
        </tr>
      </table>
      <p>
        <a href="#products" class="retro-btn">{t("hero.cta.viewWork")}</a>
        &nbsp;
        <a href="#contact" class="retro-btn">{t("hero.cta.contact")}</a>
      </p>

      <hr />

      <!-- EXPERIENCE -->
      <span id="work" style="display:block;height:0;overflow:hidden;"></span>
      <h2>{t("section.experience")}</h2>
      <div class="table-scroll">
      <table width="100%" cellpadding="4" cellspacing="2" border="1" class="zebra">
        <tr>
          <th>{t("retro.exp.period")}</th>
          <th>{t("retro.exp.type")}</th>
          <th>{t("retro.exp.role")}</th>
          <th>{t("retro.exp.company")}</th>
          <th>{t("retro.exp.focus")}</th>
          <th>{t("retro.exp.highlights")}</th>
          <th>{t("retro.exp.technologies")}</th>
        </tr>
        {experience.map((e) => {
          const ongoing = isOngoing(e);
          const endLabel = ongoing ? t("timeline.present") : formatPeriod(e.period.end);
          const startLabel = formatPeriod(e.period.start);
          const typeLabel = e.type === "academic" ? t("retro.exp.typeAcademic") : t("retro.exp.typeWork");
          return (
            <tr class={ongoing ? "row-current" : ""}>
              <td class="mono period-cell">
                <div><b>{t("retro.exp.from")}</b> {startLabel}</div>
                <div><b>{t("retro.exp.to")}</b>&nbsp;&nbsp;&nbsp;{endLabel}</div>
              </td>
              <td class="mono"><small>{typeLabel}</small></td>
              <td><b>{e.role}</b></td>
              <td>{e.company}</td>
              <td>{e.focus ?? ""}</td>
              <td>
                <ul class="tags">
                  {e.highlights.map((h) => <li>{h}</li>)}
                </ul>
              </td>
              <td class="mono"><small>{e.technologies.join(", ")}</small></td>
            </tr>
          );
        })}
      </table>
      </div>

      <hr />

      <!-- PUBLICATIONS -->
      <span id="research" style="display:block;height:0;overflow:hidden;"></span>
      <h2>{t("section.publications")}</h2>
      <div class="table-scroll">
      <table width="100%" cellpadding="4" cellspacing="2" border="1">
        <tr>
          <th>{t("retro.pub.year")}</th>
          <th>{t("retro.pub.title")}</th>
          <th>{t("retro.pub.abstract")}</th>
          <th>{t("retro.pub.authors")}</th>
          <th>{t("retro.pub.status")}</th>
          <th>{t("retro.pub.topics")}</th>
          <th>{t("retro.pub.link")}</th>
        </tr>
        {publications.map((p) => {
          const isRecent = p.year >= year;
          const statusKey = `publication.status.${p.status}` as const;
          return (
            <tr>
              <td class="mono">{p.year}</td>
              <td>
                <b>{p.title}</b>
                {isRecent && <span class="new-badge">NEW!</span>}
              </td>
              <td><small><i>{p.tldr ?? ""}</i></small></td>
              <td><small>{p.authors.join("; ")}</small></td>
              <td><i>{t(statusKey)}</i></td>
              <td><small>{p.topics.join(", ")}</small></td>
              <td>
                {p.link && <a href={p.link} target="_blank" rel="noopener">{t("publication.viewPaper")}</a>}
                {p.doi && <div class="mono"><small>doi:{p.doi}</small></div>}
              </td>
            </tr>
          );
        })}
      </table>
      </div>

      <hr />

      <!-- FEATURED PRODUCTS -->
      <span id="products" style="display:block;height:0;overflow:hidden;"></span>
      <h2>{t("section.products")}</h2>
      <div class="table-scroll">
      <table width="100%" cellpadding="4" cellspacing="2" border="1">
        <tr>
          <th>{t("retro.prod.name")}</th>
          <th>{t("retro.prod.year")}</th>
          <th>{t("retro.prod.role")}</th>
          <th>{t("retro.prod.description")}</th>
          <th>{t("retro.prod.tech")}</th>
          <th>{t("retro.prod.image")}</th>
          <th>{t("retro.prod.link")}</th>
        </tr>
        {products.map((pr) => (
          <tr>
            <td>
              <b>{pr.name}</b>
              {pr.nda && <><br /><small>[ {t("product.nda")} ]</small></>}
            </td>
            <td class="mono">{pr.year ?? "—"}</td>
            <td>
              {(pr.role === "Core Engineer" || pr.role === "Główny inżynier")
                ? <span style="white-space:nowrap"><span class="blink">★</span> {pr.role} <span class="blink">★</span></span>
                : pr.role}
            </td>
            <td><small>{pr.description}</small></td>
            <td class="mono"><small>{pr.technologies.join(", ")}</small></td>
            <td align="center">
              {pr.image ? (
                <img src={pr.image} alt={`[Screenshot of ${pr.name}]`} width="120" />
              ) : (
                <span class="bevel-in">[IMG]</span>
              )}
            </td>
            <td>
              {pr.link && <a href={pr.link} target="_blank" rel="noopener">{t("product.viewProduct")}</a>}
            </td>
          </tr>
        ))}
      </table>
      </div>

      <hr />

      <!-- CONTACT -->
      <span id="contact" style="display:block;height:0;overflow:hidden;"></span>
      <h2>{t("section.contact")}</h2>
      <p><b>{t("contact.headline")}</b></p>
      <p><i>{t("contact.subheadline").replace(/^\/\/\s*/, "")}</i></p>

      <div class="contact-cols">
        <div class="contact-col">
          <h3>{t("contact.email.label")}</h3>
          <p>
            <a href="mailto:contact@miloszmisiek.com">contact@miloszmisiek.com</a>
          </p>
        </div>
        <div class="contact-col">
          <h3>{t("retro.links.heading")}</h3>
          <ul>
            <li><a href="https://github.com/miloszmisiek">{t("contact.github")}</a></li>
            <li><a href="https://www.linkedin.com/in/milosz-misiek/">{t("contact.linkedin")}</a></li>
            <li><a href="https://www.researchgate.net/profile/Milosz-Misiek">{t("contact.researchgate")}</a></li>
          </ul>
        </div>
      </div>

      <h3>{t("retro.contact.drop")}</h3>
      <form name="retro-contact" method="POST" data-netlify="true" class="retro-form">
        <input type="hidden" name="form-name" value="retro-contact" />
        <p>
          <label>{t("contact.form.name.label")}<br />
            <input type="text" name="name" autocomplete="name" required />
          </label>
        </p>
        <p>
          <label>{t("contact.form.email.label")}<br />
            <input type="email" name="email" autocomplete="email" required />
          </label>
        </p>
        <p>
          <label>{t("contact.form.message.label")}<br />
            <textarea name="message" rows="6" autocomplete="off" required></textarea>
          </label>
        </p>
        <p>
          <input type="submit" value={t("contact.form.submit")} />
        </p>
      </form>

      <hr />

      <!-- GUESTBOOK CTA -->
      <div class="center">
        <a href={locale === "pl" ? "/pl/guestbook" : "/guestbook"} class="retro-btn">{t("retro.guestbook.cta")}</a>
      </div>

      <hr />

      <footer class="retro-footer">
        <p>
          © {year} MILOSZ MISIEK &nbsp;|&nbsp;
          Webmaster: <a href="mailto:contact@miloszmisiek.com">contact@miloszmisiek.com</a> &nbsp;|&nbsp;
          Last Updated: <span class="mono">{buildDate}</span> &nbsp;|&nbsp;
          Visitor #<span class="hits" id="hits">0000000</span>
        </p>
        <p><small>{t("retro.footer.modem")}</small></p>
      </footer>
      </div>{/* end .page-inner */}
    </div>

    <script is:inline>
      console.log("Welcome to MILOSZ MISIEK v1.0 (1996 Edition)");

      // Hide dial-up bar after fill animation
      setTimeout(function () {
        var d = document.getElementById("dialup");
        if (d) d.style.display = "none";
      }, 3100);

      // Hit counter — real count via Netlify Blobs, localStorage fallback
      (function () {
        var el = document.getElementById("hits");
        fetch("/api/hits", { method: "POST" })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            if (el) el.textContent = String(d.count).padStart(7, "0");
            try { localStorage.setItem("retro_hits", String(d.count)); } catch (e) {}
          })
          .catch(function () {
            try {
              var n = parseInt(localStorage.getItem("retro_hits") || "1336521", 10) + 1;
              localStorage.setItem("retro_hits", String(n));
              if (el) el.textContent = String(n).padStart(7, "0");
            } catch (e) {}
          });
      })();


      // MIDI toggle (plays /retro_tune.mp3 looped)
      var midi = document.getElementById("midi-toggle");
      if (midi) {
        var on = false;
        var audio = new Audio("/retro_tune.mp3");
        audio.loop = true;
        audio.volume = 0.6;
        midi.addEventListener("click", function () {
          on = !on;
          midi.textContent = "♪ MIDI: " + (on ? "ON " : "OFF");
          midi.setAttribute("aria-pressed", on ? "true" : "false");
          if (on) {
            audio.play().catch(function () {
              on = false;
              midi.textContent = "♪ MIDI: OFF";
            });
          } else {
            audio.pause();
          }
        });
        window.addEventListener("beforeunload", function () {
          audio.pause();
        });
      }

      // Exit retro mode: clear flag and return home
      function clearRetro() {
        try { localStorage.removeItem("retro_mode"); } catch (e) {}
        window.location.href = document.getElementById("exit-retro").dataset.home;
      }
      var ex1 = document.getElementById("exit-retro");
      if (ex1) ex1.addEventListener("click", clearRetro);

      // Mark this session as retro-on so refreshes stay
      try { localStorage.setItem("retro_mode", "on"); } catch (e) {}
    </script>
  </body>
</html>
