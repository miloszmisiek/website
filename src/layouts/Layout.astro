---
import '../styles/global.css';
import type { Locale } from '../i18n';

interface Props {
  title: string;
  lang: Locale;
}

const { title, lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Milosz Misiek Portfolio" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="selection:bg-foreground selection:text-background">
    <slot />
  </body>
</html>
