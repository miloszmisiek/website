---
import Logo from "../components/logo/Logo.astro";
import NavLink from "../components/nav-links/NavLink.astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";
import MobileMenu from "../components/MobileMenu.astro";
import { getTranslations } from "../i18n";

const t = getTranslations(Astro.currentLocale);

const navLinks = [
  { key: "nav.research" as const, href: "#publications" },
  { key: "nav.work" as const, href: "#products" },
  { key: "nav.contact" as const, href: "#contact" },
];

const translatedLinks = navLinks.map((link) => ({
  label: t(link.key),
  href: link.href,
}));
---

<header
  class="scroll-bg sticky top-0 z-header text-sm font-mono tracking-widest uppercase text-muted border-border pt-4 pb-4 will-change-transform data-[hidden]:-translate-y-full"
>
  <div class="page-container flex justify-between items-center">
    <div class="flex items-center gap-4">
      <span class="text-foreground/55 hidden md:inline-block">~/</span>
      <Logo />
    </div>
    <nav class="flex items-center gap-6 md:gap-8">
      <div class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <NavLink href={link.href} label={t(link.key)} />
          ))
        }
      </div>

      <div class="hidden md:block w-[1px] h-6 bg-foreground/20 mx-2"></div>

      <div class="flex items-center gap-3">
        <ThemeSwitcher />
        <LanguageSwitcher />
        <MobileMenu links={translatedLinks} />
      </div>
    </nav>
  </div>
</header>

<script>
  import { scrollToInitialHash } from "../scripts/scroll-to-initial-hash";

  const SCROLL_THRESHOLD = 40;
  const HIDE_DELTA = 8;
  const HASH_OFFSET = 16;
  const FALLBACK_HEADER_HEIGHT = 76;

  const header = document.querySelector<HTMLElement>("header");
  const mobileMenu = document.getElementById("mobile-menu");

  if (!header) {
    throw new Error("Header element not found");
  }

  const getHeaderHeight = () => header.offsetHeight || FALLBACK_HEADER_HEIGHT;

  const setHeaderHeightVar = () => {
    document.documentElement.style.setProperty(
      "--header-height",
      `${getHeaderHeight()}px`,
    );
  };

  const toggleScrolled = (scrolled: boolean) => {
    header.toggleAttribute("data-scrolled", scrolled);
    mobileMenu?.toggleAttribute("data-scrolled", scrolled);
  };

  let lastY = window.scrollY;
  let ticking = false;

  const updateScrollState = () => {
    const y = window.scrollY;
    const delta = y - lastY;
    const scrolled = y > SCROLL_THRESHOLD;

    toggleScrolled(scrolled);

    const menuOpen = mobileMenu?.hasAttribute("data-open");
    if (!menuOpen && scrolled && Math.abs(delta) > HIDE_DELTA) {
      header.toggleAttribute("data-hidden", delta > 0);
    } else if (!scrolled) {
      header.removeAttribute("data-hidden");
    }

    lastY = y;
    ticking = false;
  };

  const onScroll = () => {
    if (ticking) return;
    requestAnimationFrame(updateScrollState);
    ticking = true;
  };

  setHeaderHeightVar();
  scrollToInitialHash({ getHeaderHeight, hashOffset: HASH_OFFSET });
  updateScrollState();

  window.addEventListener("resize", setHeaderHeightVar, { passive: true });
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
