---
// GOOD
import Button from "./button/Button.astro";
import IconSun from "./icons/IconSun.astro";
import IconMoon from "./icons/IconMoon.astro";
---

<Button
  id="theme-toggle"
  type="button"
  variant="icon"
  aria-label="Toggle theme"
>
  <IconSun id="theme-icon-sun" class="hidden" />
  <IconMoon id="theme-icon-moon" class="hidden" />
</Button>

<script>
  const Theme = { DARK: "dark", LIGHT: "light" } as const;

  type Theme = (typeof Theme)[keyof typeof Theme];
  type ThemeProps = {
    color: string;
    show: string;
    hide: string;
    label: string;
  };
  type ThemeConfig = Record<Theme, ThemeProps>;

  const STORAGE_KEY = "theme" as const;

  const IDS = {
    toggle: "theme-toggle",
    sun: "theme-icon-sun",
    moon: "theme-icon-moon",
  } as const;

  const THEME_CONFIG: ThemeConfig = {
    [Theme.DARK]: {
      color: "#050505",
      show: IDS.sun,
      hide: IDS.moon,
      label: "Switch to light theme",
    },
    [Theme.LIGHT]: {
      color: "#f8f5ef",
      show: IDS.moon,
      hide: IDS.sun,
      label: "Switch to dark theme",
    },
  };

  const isTheme = (value: string | null): value is Theme =>
    value === Theme.DARK || value === Theme.LIGHT;

  function getEffectiveTheme(): Theme {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (isTheme(stored)) return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? Theme.DARK
      : Theme.LIGHT;
  }

  function applyTheme(theme: Theme) {
    const { color, show, hide, label } = THEME_CONFIG[theme];
    document.documentElement.setAttribute("data-theme", theme);
    document
      .querySelector<HTMLMetaElement>('meta[name="theme-color"]')
      ?.setAttribute("content", color);
    document.getElementById(show)?.classList.remove("hidden");
    document.getElementById(hide)?.classList.add("hidden");
    document.getElementById(IDS.toggle)?.setAttribute("aria-label", label);
  }

  function init() {
    applyTheme(getEffectiveTheme());

    document.getElementById(IDS.toggle)?.addEventListener("click", () => {
      const next =
        getEffectiveTheme() === Theme.DARK ? Theme.LIGHT : Theme.DARK;
      localStorage.setItem(STORAGE_KEY, next);
      applyTheme(next);
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        if (!localStorage.getItem(STORAGE_KEY)) applyTheme(getEffectiveTheme());
      });
  }

  init();
</script>
