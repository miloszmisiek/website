---
// GOOD
import { AnimatedSectionTitle } from "../components/arrayTitle/AnimatedSectionTitle";
import { FadeIn } from "../components/FadeIn";
import { FADE_DELAY } from "../styles/animations";
import { PublicationDeck } from "../components/publications/deck";
import { getPublications, getTranslations } from "../i18n";

const publications = getPublications(Astro.currentLocale);
const t = getTranslations(Astro.currentLocale);
---

<section id="publications" class="mb-24 short:mb-12">
  <div class="section-label">
    <span class="section-num">02</span>
    <AnimatedSectionTitle client:load text={t("section.publications")} />
  </div>

  <FadeIn client:load delay={FADE_DELAY.sm}>
    <PublicationDeck client:load publications={publications} />
  </FadeIn>
</section>
