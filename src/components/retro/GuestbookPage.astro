---
import { getTranslations } from "../../i18n/translations";
import type { Locale } from "../../i18n/config";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = getTranslations(locale);

const retroHref = locale === "pl" ? "/pl/retro" : "/retro";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t("retro.guestbook.pageTitle")}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=VT323&display=swap"
    />
    <link rel="stylesheet" href="/retro.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="dialup" id="dialup"><div class="dialup-bar"></div></div>

    <div class="page">
      <div class="page-titlebar">
        <span>GUESTBOOK.EXE — Netscape Navigator 4.0</span>
        <div class="page-titlebar-controls">
          <span class="page-titlebar-btn" aria-hidden="true">_</span>
          <span class="page-titlebar-btn" aria-hidden="true">□</span>
          <a
            class="page-titlebar-btn page-titlebar-close"
            href={retroHref}
            aria-label={t("retro.close")}
            title={t("retro.close.tooltip")}>✕</a
          >
        </div>
      </div>

      <div class="page-inner">
        <div class="center">
          <h1>~ {t("retro.guestbook.entries")} ~</h1>
        </div>

        <div class="retro-nav">
          <a href={retroHref}>{t("retro.guestbook.back")}</a>
        </div>

        <marquee scrollamount="4">{t("retro.guestbook.marquee")}</marquee>

        <hr />

        <!-- ENTRIES TABLE -->
        <div class="table-scroll retro-desktop">
          <table
            width="100%"
            cellpadding="4"
            cellspacing="2"
            border="1"
            id="guestbook-table"
            data-empty={t("retro.guestbook.empty")}
            data-cta={t("retro.guestbook.cta")}
          >
            <tr>
              <th>#</th>
              <th>{t("retro.guestbook.name")}</th>
              <th>{t("retro.guestbook.location")}</th>
              <th>{t("retro.guestbook.message")}</th>
              <th>{t("retro.guestbook.date")}</th>
            </tr>
            <tr id="guestbook-loading">
              <td colspan="5" class="mono"
                ><i>{t("retro.guestbook.loading")}</i></td
              >
            </tr>
          </table>
        </div>

        <div id="guestbook-cards" class="retro-cards retro-mobile"
          data-empty={t("retro.guestbook.empty")}
          data-loading={t("retro.guestbook.loading")}
          data-label-location={t("retro.guestbook.location")}
          data-label-message={t("retro.guestbook.message")}
          data-label-date={t("retro.guestbook.date")}
        >
          <p id="guestbook-cards-loading" class="mono"><i>{t("retro.guestbook.loading")}</i></p>
        </div>

        <div id="guestbook-load-more-wrap" style="display:none; margin: 8px 0;">
          <button
            id="guestbook-load-more"
            class="retro-btn"
            data-label-load={t("retro.guestbook.loadMore")}
            data-label-loading={t("retro.guestbook.loadingMore")}
          >{t("retro.guestbook.loadMore")}</button>
        </div>

        <hr />

        <!-- SIGN FORM -->
        <h2>{t("retro.guestbook.heading")}</h2>
        <form
          name="retro-guestbook"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="retro-form"
          id="guestbook-form"
        >
          <input type="hidden" name="form-name" value="retro-guestbook" />
          <p style="display:none">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>
          <p>
            <label
              >{t("retro.guestbook.name")}<br />
              <input type="text" name="name" autocomplete="name" maxlength="100" required />
            </label>
          </p>
          <p>
            <label
              >{t("retro.guestbook.location")}
              <small>(optional)</small><br />
              <input
                type="text"
                name="location"
                autocomplete="off"
                placeholder={t("retro.guestbook.locationHint")}
                maxlength="100"
              />
            </label>
          </p>
          <p>
            <label
              >{t("retro.guestbook.message")}<br />
              <textarea name="message" rows="4" autocomplete="off" maxlength="2000" required
              ></textarea>
            </label>
          </p>
          <p>
            <input
              type="submit"
              id="guestbook-submit"
              value={t("retro.guestbook.submit")}
              data-submitting={t("retro.guestbook.submitting")}
            />
          </p>
        </form>

        <div
          id="guestbook-status"
          class="guestbook-status"
          style="display:none"
          data-success={t("retro.guestbook.success")}
          data-success-sub={t("retro.guestbook.successSub")}
          data-error={t("retro.guestbook.error")}
          data-try-again={t("retro.guestbook.tryAgain")}
          aria-live="polite"
        >
        </div>

        <footer class="retro-footer">
          <p>
            © {year} MILOSZ MISIEK &nbsp;|&nbsp; <a href={retroHref}
              >{t("retro.guestbook.back")}</a
            >
          </p>
        </footer>
      </div>
    </div>

    <script>
      import "../../scripts/retro/guestbook-page";
    </script>

  </body>
</html>
