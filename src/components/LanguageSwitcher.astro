---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "../i18n";

const currentLang = Astro.currentLocale as Locale;
const otherLang: Locale = currentLang === "en" ? "pl" : "en";
const switchUrl = getRelativeLocaleUrl(otherLang, "/");
---

<a
  href={switchUrl}
  class="text-xs font-mono tracking-widest text-foreground/90 hover:text-foreground transition-all duration-300 border border-border bg-white/5 backdrop-blur-sm w-11 h-11 p-0 hover:border-foreground/30 hover:bg-white/10 inline-flex items-center justify-center cursor-pointer"
  aria-label={`Switch to ${otherLang === "en" ? "English" : "Polish"}`}
>
  {otherLang.toUpperCase()}
</a>
