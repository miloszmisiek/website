---
import Button from "../components/button/Button.astro";
import { AnimatedSectionTitle } from "../components/arrayTitle/AnimatedSectionTitle";
import { FadeIn } from "../components/FadeIn";
import { FADE_DELAY } from "../styles/animations";
import { ContactForm } from "../components/contact/ContactForm";
import { getTranslations } from "../i18n";

const t = getTranslations(Astro.currentLocale);
---

<form
  name="contact"
  method="POST"
  action="/"
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  hidden
>
  <input type="hidden" name="form-name" value="contact" />
  <input type="text" name="name" />
  <input type="email" name="email" />
  <textarea name="message"></textarea>
  <input type="text" name="bot-field" />
</form>

<section id="contact" class="mb-16 short:mb-10">
  {/* Section Header */}
  <div class="section-label">
    <span class="section-num">04</span>
    <AnimatedSectionTitle client:load text={t("section.contact")} />
  </div>

  <FadeIn client:load delay={FADE_DELAY.sm} scrollTriggered>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 short:lg:gap-10 items-start">
      {/* ── Left: info + social links ── */}
      <div class="lg:col-span-5 flex flex-col gap-8 short:gap-5">
        {/* Headline */}
        <div class="flex flex-col gap-4 short:gap-3">
          <h2 class="text-heading-contact text-5xl md:text-5xl lg:text-6xl short:text-[2.5rem] max-w-[12ch] short:max-w-[15ch] [text-wrap:balance]">
            {t("contact.headline")}
          </h2>
          <p
            class="text-foreground/70 text-base md:text-lg short:text-base leading-relaxed max-w-md [text-wrap:balance]"
          >
            <span class="text-foreground/45 font-mono mr-2">{"//"}</span>
            {t("contact.subheadline").replace("// ", "")}
          </p>
        </div>

        {/* Email pill */}
        <div class="flex flex-col gap-2">
          <span
            class="text-micro font-mono uppercase tracking-technical text-foreground/55"
          >
            {t("contact.email.label")}
          </span>
          <a
            href="mailto:contact@miloszmisiek.com?subject=Contact%20from%20Portfolio&body=Hi%20Milosz%2C%0A%0AI%20came%20across%20your%20portfolio%20and%20would%20like%20to%20get%20in%20touch.%0A%0A[Please%20replace%20this%20with%20your%20message]%0A%0ABest%20Regards%0A"
            class="group inline-flex items-center gap-3 w-fit border border-foreground/15 rounded-none px-4 py-3 short:px-3 short:py-2 hover:border-foreground/30 hover:bg-foreground/[0.03] transition-[border-color,background-color] duration-300 cursor-pointer focus-ring"
            translate="no"
          >
            {/* Arrow */}
            <svg
              aria-hidden="true"
              class="w-3.5 h-3.5 text-muted/70 group-hover:text-foreground/70 group-hover:translate-x-0.5 transition-[color,transform] duration-200 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
            </svg>
            <span
              class="text-xs font-mono text-foreground/80 group-hover:text-foreground tracking-wide transition-colors duration-200"
            >
              contact@miloszmisiek.com
            </span>
          </a>
        </div>

        {/* Social links */}
        <div class="flex flex-wrap gap-3">
          {/* GitHub */}
          <Button
            href="https://github.com/miloszmisiek"
            variant="secondary"
            target="_blank"
            class="focus-ring gap-2"
            aria-label="GitHub profile"
          >
            <img
              src="/icons/github.svg"
              alt=""
              aria-hidden="true"
              width="14"
              height="14"
              class="w-3.5 h-3.5 shrink-0 icon-invert"
            />
            {t("contact.github")}
          </Button>

          {/* LinkedIn */}
          <Button
            href="https://www.linkedin.com/in/milosz-misiek/"
            variant="secondary"
            class="focus-ring gap-2"
            target="_blank"
            aria-label="LinkedIn profile"
          >
            <img
              src="/icons/linkedin.svg"
              alt=""
              aria-hidden="true"
              width="14"
              height="14"
              class="w-3.5 h-3.5 shrink-0 icon-invert"
            />
            {t("contact.linkedin")}
          </Button>

          {/* ResearchGate */}
          <Button
            href="https://www.researchgate.net/profile/Milosz-Misiek"
            variant="secondary"
            target="_blank"
            class="focus-ring gap-2"
            aria-label="ResearchGate profile"
          >
            <img
              src="/icons/researchgate.svg"
              alt=""
              aria-hidden="true"
              width="14"
              height="14"
              class="w-3.5 h-3.5 shrink-0 icon-invert"
            />
            {t("contact.researchgate")}
          </Button>
        </div>

        {/* Decorative code-like notation */}
        <div class="hidden lg:block mt-auto pt-8 short:pt-4">
          <div
            class="font-mono text-micro text-foreground/40 tracking-widest leading-relaxed select-none"
          >
            <div>$ whoami</div>
            <div>milosz.misiek</div>
            <br />
            <div>$ cat profile.json</div>
            <div>{"{"}</div>
            <div class="pl-4">{'role: "software engineer",'}</div>
            <div class="pl-4">{'location: "Szczecin, PL",'}</div>
            <div class="pl-4">{'focus: "performance & scalable systems"'}</div>
            <div>{"}"}</div>
          </div>
        </div>
      </div>

      {/* ── Right: terminal form card ── */}
      <div class="lg:col-span-6 lg:col-start-7">
        <ContactForm client:load />
      </div>
    </div>
  </FadeIn>
</section>
