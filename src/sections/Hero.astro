---
import Button from "../components/button/Button.astro";
import { FadeIn } from "../components/FadeIn";
import { FADE_DELAY } from "../styles/animations";
import { getTranslations } from "../i18n";
import MobileTerminalBar from "../components/hero/MobileTerminalBar.astro";
import DesktopTerminal from "../components/hero/DesktopTerminal.astro";
import ScrollIndicator from "../components/hero/ScrollIndicator.astro";

const t = getTranslations(Astro.currentLocale);
---

<section
  id="hero"
  class="pb-12 min-h-[calc(100svh-76px)] flex flex-col justify-start short:justify-center md2:pb-0 relative"
>
  <div class="flex-1 short:hidden" aria-hidden="true"></div>
  <FadeIn client:load delay={FADE_DELAY.xs}>
    <h1
      class="text-heading-xl text-5xl md:text-6xl lg:text-7xl short:text-[3.5rem] heroShort:text-5xl mb-8 sm:mb-12 md:mb-16 short:mb-10 heroShort:mb-8 heroShort:max-w-xl max-w-4xl lg:max-w-3xl text-transparent bg-clip-text text-gradient-heading [text-wrap:balance]"
    >
      {t("hero.typewriter")}
    </h1>
    <div
      class="grid grid-cols-1 md2:grid-cols-12 gap-8 md2:gap-12 text-muted font-light leading-relaxed text-sm md2:border-l-2 md2:border-line md2:pl-10 md2:ml-2"
    >
      <div class="md2:col-span-6 mlg:col-span-7 max-w-2xl pt-2">
        <p class="text-lg md:text-xl lg:text-2xl short:text-xl heroShort:text-lg text-foreground/75 leading-relaxed lg:leading-body-loose mb-4 short:mb-2">
          <span class="text-foreground/50 font-mono mr-3" aria-hidden="true"
            >{"//"}</span
          >
          {t("hero.bio.first")}
        </p>
        <p class="text-lg md:text-xl lg:text-2xl short:text-xl heroShort:text-lg text-foreground/75 leading-relaxed lg:leading-body-loose mb-8 sm:mb-10 short:mb-8">
          <span class="text-foreground/50 font-mono mr-3" aria-hidden="true"
            >{"//"}</span
          >
          {t("hero.bio.second")}
        </p>
        <div class="flex flex-wrap justify-start items-center gap-4">
          <Button href="#products" variant="primary">
            {t("hero.cta.viewWork")}
          </Button>
          <Button href="#contact" variant="secondary">
            {t("hero.cta.contact")}
          </Button>
        </div>

        <MobileTerminalBar />
      </div>

      <DesktopTerminal />
    </div>
  </FadeIn>
  <div class="flex-[2] short:hidden" aria-hidden="true"></div>

  <ScrollIndicator />
</section>

<script>
  // iOS Safari does not reliably honour svh/lvh; the section visibly resizes
  // when the URL bar collapses. Lock min-height in px once on touch devices.
  const hero = document.getElementById("hero");
  if (hero && matchMedia("(hover: none) and (pointer: coarse)").matches) {
    const headerH = document.querySelector("header")?.offsetHeight ?? 76;
    hero.style.minHeight = `${window.innerHeight - headerH}px`;
  }
</script>
